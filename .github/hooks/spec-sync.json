{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "./scripts/sync-specs.sh",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./scripts/generate-full-specs.sh",
        "timeout": 30
      }
    ]
  }
}
