{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "scripts/sync-specs.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts\\sync-specs.ps1",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "scripts/generate-full-specs.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts\\generate-full-specs.ps1",
        "timeout": 30
      }
    ]
  }
}
